{
  "name": "deriv-5-graficos-ic-integrado",
  "version": "0.3.0",
  "description": "Cinco gráficos livianos Deriv con dibujo y panel IC DEMO/REAL.",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:web && electron .",
    "build:web": "webpack --mode production",
    "pack:win": "npm run build:web && electron-builder --win portable"
  },
  "dependencies": {
    "lightweight-charts": "5.2.0"
  },
  "devDependencies": {
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "7.1.2",
    "electron": "31.7.7",
    "electron-builder": "24.13.3",
    "style-loader": "4.0.0",
    "webpack": "5.98.0",
    "webpack-cli": "6.0.1"
  },
  "build": {
    "appId": "com.gabriel.deriv5graficosic",
    "productName": "Deriv 5 Graficos IC",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
